filter(!(id == 279 & date > as.Date("2022-12-29"))) %>%
filter(!(id == 323 & date > as.Date("2024-01-14"))) %>%
filter(!(id == 327 & date > as.Date("2024-12-31"))) %>%
filter(!(id == 347 & date < as.Date("2024-12-10"))) %>%
filter(!(id == 210 & date > as.Date("2020-12-31"))) %>%
