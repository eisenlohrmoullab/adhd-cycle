library(readxl)
library(dplyr)
library(janitor)
library(ggplot2)
library(ggpubr)
path_trait <- "~/Library/CloudStorage/Box-Box/00 - CLEAR Lab (Locked Folders)/02 - Data Management, Analysis, and Papers/Studies_Projects/CYCLEADHD/02_datasets/01_raw_data/SCID_Meds/20251027_michelle_dx_stimulant.xlsx"
# NOTE: update this path to wherever you actually store the file in Box.
# ---- 1. Sheet 1: Informant (2ndReporters) + SCID ---------------------------
trait_informant <- read_excel(path_trait, sheet = "2ndReporters + SCID") %>%
# Drop the empty spacer column ("Unnamed: 147" in pandas → "...147" or similar in R;
# safest to drop any column that's entirely NA)
remove_empty(which = "cols") %>%
# Drop the 3 junk rows at the bottom of the sheet (label rows with NA id,
# one of which literally says "Second Reporters" in the date field)
filter(!is.na(id)) %>%
# Coerce id to match the daily dataset (factor with integer-looking levels)
mutate(id = as.factor(as.integer(id)))
cat("Informant trait data loaded:",
nrow(trait_informant), "rows,",
ncol(trait_informant), "cols,",
n_distinct(trait_informant$id), "unique ids\n")
# Sanity check: should be 0 duplicate ids now
stopifnot(sum(duplicated(trait_informant$id)) == 0)
# ---- 2. Sheet 2: Self-reports ----------------------------------------------
trait_self_raw <- read_excel(path_trait, sheet = "self-reports") %>%
# Standardize the id column name to match daily dataset
rename(id = Participant_ID) %>%
mutate(id = as.factor(as.integer(id)))
# Handle the id 348 duplicate:
# Both rows are 137/137 complete but differ on 72 columns (likely two survey administrations).
# Defaulting to the LAST row (most recent administration). Flagging so Tory can override.
dup_ids_self <- trait_self_raw %>%
group_by(id) %>%
filter(n() > 1) %>%
pull(id) %>% unique()
if (length(dup_ids_self) > 0) {
cat("WARNING: self-report sheet has duplicated ids:",
paste(as.character(dup_ids_self), collapse = ", "),
"\n  → Keeping the LAST row for each. Review source if this is wrong.\n")
}
trait_self <- trait_self_raw %>%
group_by(id) %>%
slice_tail(n = 1) %>%   # change to slice_head(n=1) for first row, or handle manually
ungroup()
cat("Self-report trait data loaded:",
nrow(trait_self), "rows,",
ncol(trait_self), "cols,",
n_distinct(trait_self$id), "unique ids\n")
stopifnot(sum(duplicated(trait_self$id)) == 0)
# ---- 3. Left-join both trait sources onto the daily dataset ----------------
# We need to resolve column-name collisions BEFORE joining. The trait sheets
# share some column names with the daily dataset (e.g. `impair_score`, `anger_score`
# appear in both informant and self sheets; `id` is the join key in all three).
# Prefix informant cols with `inf_` and self cols with `slf_` (except id).
trait_informant_pref <- trait_informant %>%
rename_with(.fn = ~ paste0("inf_", .x), .cols = -id)
trait_self_pref <- trait_self %>%
rename_with(.fn = ~ paste0("slf_", .x), .cols = -id)
# id dtype check — must match cycle_df_scaled$id (factor in your daily data)
cat("id class check:\n")
cat("  cycle_df_scaled$id:    ", class(cycle_df_scaled$id), "\n")
cat("  trait_informant_pref$id:", class(trait_informant_pref$id), "\n")
cat("  trait_self_pref$id:    ", class(trait_self_pref$id), "\n")
# Join
cycle_df_scaled <- cycle_df_scaled %>%
left_join(trait_informant_pref, by = "id") %>%
left_join(trait_self_pref,      by = "id")
# rename inf_finaldxMM to finaldxMM for easier reference in future code
cycle_df_scaled <- cycle_df_scaled %>%
rename(finaldxMM = inf_finaldxMM)%>%
rename(takes_stim = inf_Trait_Stimulant)
cat("\nMerge complete. cycle_df_scaled now has",
ncol(cycle_df_scaled), "columns and",
nrow(cycle_df_scaled), "rows.\n")
# ---- 4. Merge diagnostics --------------------------------------------------
daily_ids    <- unique(as.character(cycle_df_scaled$id))
inf_ids      <- unique(as.character(trait_informant$id))
self_ids     <- unique(as.character(trait_self$id))
cat("\n--- Coverage diagnostics ---\n")
cat("Daily ids:                         ", length(daily_ids), "\n")
cat("Daily ids with informant trait:    ",
sum(daily_ids %in% inf_ids),  "/", length(daily_ids), "\n")
cat("Daily ids with self trait:         ",
sum(daily_ids %in% self_ids), "/", length(daily_ids), "\n")
cat("Daily ids missing informant trait: ",
paste(sort(setdiff(daily_ids, inf_ids)), collapse = ", "), "\n")
cat("Daily ids missing self trait:      ",
paste(sort(setdiff(daily_ids, self_ids)), collapse = ", "), "\n")
cat("Trait ids (informant) NOT in daily:",
paste(sort(setdiff(inf_ids, daily_ids)), collapse = ", "), "\n")
cat("Trait ids (self) NOT in daily:     ",
paste(sort(setdiff(self_ids, daily_ids)), collapse = ", "), "\n")
# Spot-check: verify trait values repeat correctly within a participant
spot_id <- daily_ids[1]
n_unique_inf_vals <- cycle_df_scaled %>%
filter(id == spot_id) %>%
summarise(n = n_distinct(inf_EF_sum_score, na.rm = FALSE)) %>%
pull(n)
cat("\nSpot check for id", spot_id,
"— inf_EF_sum_score should have 1 unique value across all their days. Got:",
n_unique_inf_vals, "\n")
